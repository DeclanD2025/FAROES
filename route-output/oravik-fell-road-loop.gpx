  <ns0:metadata>
    <ns0:name>Øravík fell-and-road loop</ns0:name>
    <ns0:desc>Mixed-surface loop from Við á 7 using the opening of the official Øravík–Fámjin village path, then the old Fámjin road back to Øravík. Not an all-road run; use only in suitable visibility and ground conditions.</ns0:desc>
  </ns0:metadata>
  <ns0:wpt lat="61.53244980610907" lon="-6.810877108946443">
    <ns0:ele>6.0</ns0:ele>
    <ns0:name>Bønhúsið — Start / Finish (about 112 m from Við á 7)</ns0:name>
  </ns0:wpt>
  <ns0:wpt lat="61.525677144527435" lon="-6.831779228523374">
    <ns0:name>Leave village path — turn onto old Fámjin road</ns0:name>
  </ns0:wpt>
